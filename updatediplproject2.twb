            <groupfilter function='crossjoin' user:ui-action-filter='[Action1_E790F86973B146B98EBE65BE5463713F]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[batsman]' />
              <groupfilter function='level-members' level='[team_name]' />
