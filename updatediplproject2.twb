          <formatted-text>
            <run fontname='Tableau Bold'>Max. Highest Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_match_data+' name='federated.1wqhvx50j05rl611momtj1usna7u' />
          </datasources>
          <datasource-dependencies datasource='federated.1wqhvx50j05rl611momtj1usna7u'>
            <column caption='overall Highest sccore' datatype='real' name='[Calculation_0514321914966017]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Calculation_0818886101700612]) }' />
            </column>
            <column caption='highest score team and match detail' datatype='string' name='[Calculation_0514321915490307]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [first_ings_score] = [Calculation_0514321914966017] THEN&#13;&#10;    [team1] + &quot; vs &quot; + [team2]&#13;&#10;&#13;&#10;ELSEIF [second_ings_score] = [Calculation_0514321914966017] THEN&#13;&#10;     [team2] + &quot; vs &quot; + [team1]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Match High Score' datatype='real' name='[Calculation_0818886101700612]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [first_ings_score] &gt; [second_ings_score] THEN&#13;&#10;    [first_ings_score]&#13;&#10;ELSE&#13;&#10;    [second_ings_score]&#13;&#10;END' />
            </column>
            <column caption='Highest Score' datatype='real' name='[Calculation_1342527982190596]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MAX([first_ings_score],[second_ings_score])' />
            </column>
            <column datatype='string' name='[Match]' role='dimension' type='nominal' />
            <column caption='First Ings Score' datatype='real' name='[first_ings_score]' role='measure' type='quantitative' />
